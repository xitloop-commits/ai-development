{
  "info": {
    "_postman_id": "broker-service-full-collection",
    "name": "Broker Service — Complete API",
    "description": "Complete Postman collection for the Broker Service REST API.\n\nCovers all endpoints: status, config, token, orders, positions, margin, exit-all, kill switch, scrip master, option chain, charts (intraday + historical), and trade book.\n\n**Setup:**\n1. Set the `baseUrl` variable (default: http://localhost:3000)\n2. Start the server: `pnpm dev`\n3. Ensure a broker adapter is active (Dhan or Mock)\n\n**Variable `orderId`** is auto-captured from the Place Order response for use in Modify/Cancel/Get Order requests.\n\n**Security IDs:** All example security IDs are verified from the Dhan scrip master CSV (as of Apr 2026). Use the Scrip Master Lookup request to find IDs for other instruments.\n\n**Key Security IDs:**\n- NIFTY 50 Index: 13\n- BANKNIFTY Index: 25\n- HDFC Bank (Equity): 1333\n- Reliance Industries (Equity): 2885\n- TCS (Equity): 11536\n- NIFTY APR FUT: 66691\n- NIFTY 28 APR 24000 CE: 72263\n- CRUDEOIL APR FUT: 486502\n- GOLD JUN FUT: 459277\n- SILVER MAY FUT: 457532",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Status & Health",
      "item": [
        {
          "name": "GET Broker Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "status"]
            },
            "description": "Connection + token + kill switch status overview."
          },
          "response": []
        },
        {
          "name": "GET Token Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/token/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "token", "status"]
            },
            "description": "Check if the current broker access token is valid and when it expires."
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Config",
      "item": [
        {
          "name": "GET Active Config",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/config",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "config"]
            },
            "description": "Get the active broker config. Access token is masked in the response."
          },
          "response": []
        },
        {
          "name": "GET All Configs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/configs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "configs"]
            },
            "description": "List all broker configs (Dhan, Mock, etc.). Tokens are masked."
          },
          "response": []
        },
        {
          "name": "POST Create/Update Config",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brokerId\": \"dhan\",\n  \"displayName\": \"Dhan\",\n  \"isActive\": true,\n  \"isPaperBroker\": false,\n  \"credentials\": {\n    \"accessToken\": \"YOUR_ACCESS_TOKEN_HERE\",\n    \"clientId\": \"YOUR_CLIENT_ID_HERE\",\n    \"status\": \"valid\",\n    \"updatedAt\": 0,\n    \"expiresIn\": 86400000\n  },\n  \"settings\": {\n    \"orderEntryOffset\": 1,\n    \"defaultSL\": 2,\n    \"defaultTP\": 5,\n    \"orderType\": \"LIMIT\",\n    \"productType\": \"INTRADAY\"\n  },\n  \"capabilities\": {\n    \"bracketOrder\": true,\n    \"coverOrder\": true,\n    \"websocket\": true,\n    \"optionChain\": true\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/broker/config",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "config"]
            },
            "description": "Create or update a broker config. Requires `brokerId` and `displayName`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Token Management",
      "item": [
        {
          "name": "GET Token Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/token/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "token", "status"]
            },
            "description": "Check if the access token is valid."
          },
          "response": []
        },
        {
          "name": "POST Update Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"YOUR_NEW_ACCESS_TOKEN_HERE\",\n  \"clientId\": \"YOUR_CLIENT_ID_HERE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/broker/token/update",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "token", "update"]
            },
            "description": "Update the Dhan access token. Also persists to MongoDB.\n\nGet a new token from: https://web.dhan.co/api-access"
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. Orders",
      "item": [
        {
          "name": "POST Place Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data && jsonData.data.orderId) {",
                  "    pm.collectionVariables.set('orderId', jsonData.data.orderId);",
                  "    console.log('Captured orderId: ' + jsonData.data.orderId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"instrument\": \"NIFTY\",\n  \"exchange\": \"NSE_FNO\",\n  \"transactionType\": \"BUY\",\n  \"optionType\": \"CE\",\n  \"strike\": 24000,\n  \"expiry\": \"2026-04-28\",\n  \"quantity\": 65,\n  \"price\": 150,\n  \"orderType\": \"LIMIT\",\n  \"productType\": \"INTRADAY\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/broker/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "orders"]
            },
            "description": "Place a new order. The `orderId` from the response is auto-saved to the collection variable for use in Modify/Cancel/Get.\n\nBlocked when kill switch is active (returns 403)."
          },
          "response": []
        },
        {
          "name": "GET Order Book",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "orders"]
            },
            "description": "Get all orders for today (order book)."
          },
          "response": []
        },
        {
          "name": "PUT Modify Order",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 160,\n  \"quantity\": 65,\n  \"orderType\": \"LIMIT\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/broker/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "orders", "{{orderId}}"]
            },
            "description": "Modify a pending order. Uses the `orderId` captured from Place Order.\n\nBlocked when kill switch is active (returns 403)."
          },
          "response": []
        },
        {
          "name": "DELETE Cancel Order",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "orders", "{{orderId}}"]
            },
            "description": "Cancel a pending order. Uses the `orderId` captured from Place Order."
          },
          "response": []
        }
      ]
    },
