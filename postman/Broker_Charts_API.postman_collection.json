{
  "info": {
    "_postman_id": "broker-service-full-collection",
    "name": "Broker Service — Complete API",
    "description": "Complete Postman collection for the Broker Service REST API.\n\nCovers all 24 endpoints: status, config, token, orders, positions, margin, exit-all, kill switch, scrip master, option chain, charts (intraday + historical), and trade book.\n\n**Setup:**\n1. Set the `baseUrl` variable (default: http://localhost:3000)\n2. Start the server: `pnpm dev`\n3. Ensure a broker adapter is active (Dhan or Mock)\n\n**Variable `orderId`** is auto-captured from the Place Order response for use in Modify/Cancel/Get Order requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Status & Health",
      "item": [
        {
          "name": "GET Broker Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "status"]
            },
            "description": "Connection + token + kill switch status overview."
          },
          "response": []
        },
        {
          "name": "GET Token Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/token/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "token", "status"]
            },
            "description": "Check if the current broker access token is valid and when it expires."
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Config",
      "item": [
        {
          "name": "GET Active Config",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/config",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "config"]
            },
            "description": "Get the active broker config. Access token is masked in the response."
          },
          "response": []
        },
        {
          "name": "GET All Configs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/configs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "configs"]
            },
            "description": "List all broker configs (Dhan, Mock, etc.). Tokens are masked."
          },
          "response": []
        },
        {
          "name": "POST Create/Update Config",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brokerId\": \"dhan\",\n  \"displayName\": \"Dhan\",\n  \"isActive\": true,\n  \"isPaperBroker\": false,\n  \"credentials\": {\n    \"accessToken\": \"YOUR_ACCESS_TOKEN_HERE\",\n    \"clientId\": \"YOUR_CLIENT_ID_HERE\",\n    \"status\": \"valid\",\n    \"updatedAt\": 0,\n    \"expiresIn\": 86400000\n  },\n  \"settings\": {\n    \"orderEntryOffset\": 1,\n    \"defaultSL\": 2,\n    \"defaultTP\": 5,\n    \"orderType\": \"LIMIT\",\n    \"productType\": \"INTRADAY\"\n  },\n  \"capabilities\": {\n    \"bracketOrder\": true,\n    \"coverOrder\": true,\n    \"websocket\": true,\n    \"optionChain\": true\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/broker/config",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "config"]
            },
            "description": "Create or update a broker config. Requires `brokerId` and `displayName`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Token Management",
      "item": [
        {
          "name": "GET Token Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/token/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "token", "status"]
            },
            "description": "Check if the access token is valid."
          },
          "response": []
        },
        {
          "name": "POST Update Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"YOUR_NEW_ACCESS_TOKEN_HERE\",\n  \"clientId\": \"YOUR_CLIENT_ID_HERE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/broker/token/update",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "token", "update"]
            },
            "description": "Update the Dhan access token. Also persists to MongoDB.\n\nGet a new token from: https://web.dhan.co/api-access"
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. Orders",
      "item": [
        {
          "name": "POST Place Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data && jsonData.data.orderId) {",
                  "    pm.collectionVariables.set('orderId', jsonData.data.orderId);",
                  "    console.log('Captured orderId: ' + jsonData.data.orderId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"instrument\": \"NIFTY\",\n  \"exchange\": \"NSE_FNO\",\n  \"transactionType\": \"BUY\",\n  \"optionType\": \"CE\",\n  \"strike\": 24000,\n  \"expiry\": \"2026-04-10\",\n  \"quantity\": 50,\n  \"price\": 150,\n  \"orderType\": \"LIMIT\",\n  \"productType\": \"INTRADAY\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/broker/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "orders"]
            },
            "description": "Place a new order. The `orderId` from the response is auto-saved to the collection variable for use in Modify/Cancel/Get.\n\nBlocked when kill switch is active (returns 403)."
          },
          "response": []
        },
        {
          "name": "GET Order Book",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "orders"]
            },
            "description": "Get all orders for today (order book)."
          },
          "response": []
        },
        {
          "name": "PUT Modify Order",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 160,\n  \"quantity\": 50,\n  \"orderType\": \"LIMIT\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/broker/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "orders", "{{orderId}}"]
            },
            "description": "Modify a pending order. Uses the `orderId` captured from Place Order.\n\nBlocked when kill switch is active (returns 403)."
          },
          "response": []
        },
        {
          "name": "DELETE Cancel Order",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "orders", "{{orderId}}"]
            },
            "description": "Cancel a pending order. Uses the `orderId` captured from Place Order."
          },
          "response": []
        }
      ]
    },
    {
      "name": "5. Positions & Margin",
      "item": [
        {
          "name": "GET Positions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/positions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "positions"]
            },
            "description": "Get all current open and closed positions."
          },
          "response": []
        },
        {
          "name": "GET Margin",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/margin",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "margin"]
            },
            "description": "Get margin/fund information: available, used, total."
          },
          "response": []
        },
        {
          "name": "GET Trade Book",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/trades",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "trades"]
            },
            "description": "Get the trade book — all executed trades for today."
          },
          "response": []
        }
      ]
    },
    {
      "name": "6. Exit All & Kill Switch",
      "item": [
        {
          "name": "POST Exit All Positions",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/exit-all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "exit-all"]
            },
            "description": "Exit (square off) all open positions immediately."
          },
          "response": []
        },
        {
          "name": "POST Kill Switch — ACTIVATE",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"ACTIVATE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/broker/kill-switch",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "kill-switch"]
            },
            "description": "Activate the kill switch — halts all trading, exits all positions, blocks new orders."
          },
          "response": []
        },
        {
          "name": "POST Kill Switch — DEACTIVATE",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"DEACTIVATE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/broker/kill-switch",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "kill-switch"]
            },
            "description": "Deactivate the kill switch — resumes normal trading."
          },
          "response": []
        }
      ]
    },
    {
      "name": "7. Scrip Master",
      "item": [
        {
          "name": "GET Scrip Master Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/scrip-master/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "scrip-master", "status"]
            },
            "description": "Check if the scrip master is loaded and how many records are cached."
          },
          "response": []
        },
        {
          "name": "POST Refresh Scrip Master",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/scrip-master/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "scrip-master", "refresh"]
            },
            "description": "Force re-download the scrip master CSV from Dhan and rebuild the in-memory cache."
          },
          "response": []
        },
        {
          "name": "GET Lookup Security ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/scrip-master/lookup?symbol=NIFTY&exchange=NSE_FNO&instrumentName=OPTIDX&expiry=2026-04-10&strike=24000&optionType=CE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "scrip-master", "lookup"],
              "query": [
                { "key": "symbol", "value": "NIFTY" },
                { "key": "exchange", "value": "NSE_FNO" },
                { "key": "instrumentName", "value": "OPTIDX" },
                { "key": "expiry", "value": "2026-04-10" },
                { "key": "strike", "value": "24000" },
                { "key": "optionType", "value": "CE" }
              ]
            },
            "description": "Look up the Dhan security ID for a specific instrument.\n\nUse the returned `securityId` in chart endpoints.\n\n**Required:** symbol\n**Optional:** exchange, instrumentName, expiry, strike, optionType"
          },
          "response": []
        },
        {
          "name": "GET Expiry List (from cache)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/scrip-master/expiry-list?symbol=NIFTY&exchange=NSE_FNO&instrumentName=OPTIDX",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "scrip-master", "expiry-list"],
              "query": [
                { "key": "symbol", "value": "NIFTY" },
                { "key": "exchange", "value": "NSE_FNO" },
                { "key": "instrumentName", "value": "OPTIDX" }
              ]
            },
            "description": "Get available expiry dates from the cached scrip master.\n\n**Required:** symbol\n**Optional:** exchange, instrumentName"
          },
          "response": []
        },
        {
          "name": "GET MCX FUTCOM (Nearest Month)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/scrip-master/mcx-futcom?symbol=CRUDEOIL",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "scrip-master", "mcx-futcom"],
              "query": [
                { "key": "symbol", "value": "CRUDEOIL" }
              ]
            },
            "description": "Resolve the nearest-month MCX FUTCOM security ID for a commodity.\n\nExamples: CRUDEOIL, NATURALGAS, GOLD, SILVER"
          },
          "response": []
        }
      ]
    },
    {
      "name": "8. Option Chain",
      "item": [
        {
          "name": "GET Expiry List (Dhan API)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/option-chain/expiry-list?underlying=NIFTY&exchangeSegment=NSE_FNO",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "option-chain", "expiry-list"],
              "query": [
                { "key": "underlying", "value": "NIFTY" },
                { "key": "exchangeSegment", "value": "NSE_FNO" }
              ]
            },
            "description": "Get expiry dates from the Dhan Option Chain API (live).\n\n**Required:** underlying\n**Optional:** exchangeSegment"
          },
          "response": []
        },
        {
          "name": "GET Option Chain",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/broker/option-chain?underlying=NIFTY&expiry=2026-04-10&exchangeSegment=NSE_FNO",
              "host": ["{{baseUrl}}"],
              "path": ["api", "broker", "option-chain"],
              "query": [
                { "key": "underlying", "value": "NIFTY" },
                { "key": "expiry", "value": "2026-04-10" },
                { "key": "exchangeSegment", "value": "NSE_FNO" }
              ]
            },
            "description": "Get the full option chain for an underlying + expiry.\n\nReturns: spotPrice, rows (strike, callOI, putOI, callLTP, putLTP, etc.)\n\n**Required:** underlying, expiry\n**Optional:** exchangeSegment"
          },
          "response": []
        }
      ]
    },
