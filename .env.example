# ╔══════════════════════════════════════════════════════════════════╗
# ║  ATS — Automatic Trading System                                 ║
# ║  Environment Configuration                                      ║
# ║                                                                  ║
# ║  Copy this file to .env and fill in your values:                ║
# ║    cp .env.example .env                                         ║
# ║                                                                  ║
# ║  NEVER commit .env to version control.                          ║
# ╚══════════════════════════════════════════════════════════════════╝


# ──────────────────────────────────────────────────────────────────
# 1. SERVER
# ──────────────────────────────────────────────────────────────────

# Node environment: "development" or "production"
NODE_ENV=development

# Port the Express server listens on (default: 3000)
PORT=3000


# ──────────────────────────────────────────────────────────────────
# 2. DATABASES
# ──────────────────────────────────────────────────────────────────

# MongoDB connection string (required)
# Used for: broker configs, user settings, trade journal, alerts
# Local:  mongodb://localhost:27017/ats
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ats
MONGODB_URI=mongodb://localhost:27017/ats

# MySQL / TiDB connection string (Drizzle ORM)
# Used for: relational data (drizzle schema)
# Local:  mysql://root:password@localhost:3306/ats
# TiDB:   mysql://user:password@gateway.tidbcloud.com:4000/ats?ssl={"rejectUnauthorized":true}
DATABASE_URL=


# ──────────────────────────────────────────────────────────────────
# 3. AUTHENTICATION (Manus OAuth — auto-configured in hosted mode)
# ──────────────────────────────────────────────────────────────────

# App ID for Manus OAuth
VITE_APP_ID=

# JWT secret for session cookies
JWT_SECRET=

# OAuth server URL
OAUTH_SERVER_URL=

# Owner's OpenID (restricts access to single user)
OWNER_OPEN_ID=


# ──────────────────────────────────────────────────────────────────
# 4. FORGE API (AI features — auto-configured in hosted mode)
# ──────────────────────────────────────────────────────────────────

# Built-in Forge API URL for AI-powered features
BUILT_IN_FORGE_API_URL=

# Forge API key
BUILT_IN_FORGE_API_KEY=


# ──────────────────────────────────────────────────────────────────
# 5. BROKER SERVICE
# ──────────────────────────────────────────────────────────────────
# Broker credentials are stored in MongoDB (not in env vars).
# Use the Settings UI or REST API to configure:
#   POST /api/broker/config
#   POST /api/broker/token/update
#
# No env vars needed here — the Broker Service reads from MongoDB.


# ──────────────────────────────────────────────────────────────────
# 6. PYTHON MODULES
# ──────────────────────────────────────────────────────────────────
# These are used by the Python pipeline (option chain fetcher,
# AI decision engine, execution module, dashboard data pusher).
# All default to http://localhost:3000 if not set.

# Base URL for the Broker Service REST API
# Python modules call /api/broker/* endpoints on this URL
BROKER_URL=http://localhost:3000

# Base URL for the Dashboard REST API
# Python modules call /api/trading/* endpoints on this URL
DASHBOARD_URL=http://localhost:3000

# Enable live trading (default: false = paper trading)
# Set to "true" ONLY when you want real orders sent to Dhan
LIVE_TRADING=false


# ──────────────────────────────────────────────────────────────────
# 7. TESTING
# ──────────────────────────────────────────────────────────────────
# Tests that require MongoDB will use MONGODB_URI above.
# MockAdapter tests run without any env vars.
#
# Run all tests:     pnpm test
# Run broker tests:  pnpm vitest run server/broker/
# Type check:        pnpm check
