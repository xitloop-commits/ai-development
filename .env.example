# ╔══════════════════════════════════════════════════════════════════╗
# ║  ATS — Automatic Trading System                                 ║
# ║  Environment Configuration                                      ║
# ║                                                                  ║
# ║  Copy this file to .env and fill in your values:                ║
# ║    cp .env.example .env                                         ║
# ║                                                                  ║
# ║  NEVER commit .env to version control.                          ║
# ╚══════════════════════════════════════════════════════════════════╝


# ──────────────────────────────────────────────────────────────────
# 1. SERVER
# ──────────────────────────────────────────────────────────────────

# Node environment: "development" or "production"
NODE_ENV=development

# Port the Express server listens on (default: 3000)
PORT=3000

# Network interface the HTTP + tick-WS server binds to.
# Default: 127.0.0.1 (loopback only — same machine can connect)
# Set to 0.0.0.0 only when running behind a trusted reverse proxy that
# enforces auth + TLS. Direct LAN exposure is NOT recommended.
HTTP_HOST=127.0.0.1


# ──────────────────────────────────────────────────────────────────
# 2. DATABASES
# ──────────────────────────────────────────────────────────────────

# MongoDB connection string (required)
# Used for: broker configs, user settings, trade journal, alerts
# Local:  mongodb://localhost:27017/ats
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ats
MONGODB_URI=mongodb://localhost:27017/ats


# ──────────────────────────────────────────────────────────────────
# 3. FORGE API (AI features — auto-configured in hosted mode)
# ──────────────────────────────────────────────────────────────────

# Built-in Forge API URL for AI-powered features
BUILT_IN_FORGE_API_URL=

# Forge API key
BUILT_IN_FORGE_API_KEY=


# ──────────────────────────────────────────────────────────────────
# 5. BROKER SERVICE
# ──────────────────────────────────────────────────────────────────
# Primary broker access tokens are stored in MongoDB. Configure via:
#   POST /api/broker/config
#   POST /api/broker/token/update
#
# The headless Dhan token-refresh job reads these directly from env —
# required only if you run that job.

# Dhan client/login id (required for token-refresh job)
DHAN_CLIENT_ID=

# Dhan trading PIN (required for token-refresh job)
DHAN_PIN=

# Dhan TOTP shared secret (required for headless token-refresh job)
DHAN_TOTP_SECRET=


# ──────────────────────────────────────────────────────────────────
# 5b. TELEGRAM (alerts via tfa_bot)
# ──────────────────────────────────────────────────────────────────
# Optional. Required only when running tfa_bot helper for trade alerts.

# Telegram bot token (BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram chat id to receive alerts
TELEGRAM_CHAT_ID=


# ──────────────────────────────────────────────────────────────────
# 6. PYTHON MODULES
# ──────────────────────────────────────────────────────────────────
# These are used by the Python pipeline (option chain fetcher,
# AI decision engine, execution module, dashboard data pusher).
# All default to http://localhost:3000 if not set.

# Base URL for the Broker Service REST API
# Python modules call /api/broker/* endpoints on this URL
BROKER_URL=http://localhost:3000

# Base URL for the Dashboard REST API
# Python modules call /api/trading/* endpoints on this URL
DASHBOARD_URL=http://localhost:3000

# Enable live trading (default: false = paper trading)
# Set to "true" ONLY when you want real orders sent to Dhan
LIVE_TRADING=false


# ──────────────────────────────────────────────────────────────────
# 7. TESTING
# ──────────────────────────────────────────────────────────────────
# Tests that require MongoDB will use MONGODB_URI above.
# MockAdapter tests run without any env vars.
#
# Run all tests:     pnpm test
# Run broker tests:  pnpm vitest run server/broker/
# Type check:        pnpm check
