flowchart LR
  subgraph Strategy
    ML["ML / Strategy Agent"]
    MD["Market Data Agent"]
  end

  subgraph Server["Server / ATS Core"]
    PA["Portfolio Agent"]
    RA["Risk Control Agent"]
    EX["Execution Engine"]
    TS["Trading Store / Positions"]
    CP["Capital Module / Pools"]
  end

  subgraph Broker["Broker / Market"]
    BK["Broker Service / Market Data"]
  end

  ML -->|trade proposal| RA
  ML -->|direction/confidence/entry/target/stop| PA
  MD -->|volatility/liquidity/spread/time| RA
  MD -->|market valuation/price updates| PA
  PA -->|portfolio state / exposure / drawdown| RA
  RA -->|risk approval / position size / stop loss| EX
  EX -->|place order / exit order| BK
  BK -->|order status / fills / quotes| EX
  EX -->|position events| PA
  EX -->|execution feedback| RA
  EX -->|open/close position updates| TS
  TS -->|position snapshot| PA
  CP -->|capital state / available funds| PA
  CP -->|capital limits / margin data| RA
  PA -->|portfolio health / capacity signals| ML
  RA -->|risk signals / reject reasons| ML
  PA -->|portfolio metrics| EX
  RA -->|exit triggers| EX

  classDef agents fill:#f8f4d6,stroke:#b38f00,stroke-width:2px;
  class PA,RA agents;
  classDef systems fill:#e7f4ff,stroke:#2c6fb6,stroke-width:2px;
  class EX,TS,CP,BK systems;
  classDef inputs fill:#f2e8ff,stroke:#6d3fbf,stroke-width:2px;
  class ML,MD inputs;
