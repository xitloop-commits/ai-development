graph TD
    subgraph FEED["Feed Layer"]
        UT["Underlying Tick"]
        OT["Option Tick"]
        CS["Chain Snapshot"]
    end

    subgraph CORE["TFA Core"]
        TH["Tick Handler"]
        CH["Chain Handler"]

        subgraph STATE["State Stores"]
            UB["Underlying Buffer\n20-tick circular"]
            OB["Option Buffer\n5-tick per strike × CE/PE"]
            CC["Chain Cache\nPCR · OI totals · ΔOI\nActive Strikes · Strength"]
        end

        ATM["ATM Detector\nround(spot ÷ step) × step"]
        FA["Feature Assembler"]
    end

    subgraph OUTPUT["Output"]
        FV["Flat Vector\n180 columns per tick"]
    end

    UT --> TH
    OT --> TH
    CS --> CH

    TH --> UB
    TH --> OB
    TH --> ATM

    CH --> CC
    ATM -->|"ATM change → partial cache refresh"| CC

    UB --> FA
    OB --> FA
    ATM --> FA
    CC --> FA

    FA --> FV
