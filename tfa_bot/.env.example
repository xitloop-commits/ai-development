# ──────────────────────────────────────────────────────────────────
# tfa_bot — Trade-from-alerts helper bot
# ──────────────────────────────────────────────────────────────────
# Copy to tfa_bot/.env and fill in. NEVER commit .env.
#
# This bot listens to Telegram alerts and bridges them to Dhan via the
# main API server. Required: Dhan auth + Telegram credentials.

# ── Dhan auth (same values as root .env, but the bot reads its own copy) ──
DHAN_CLIENT_ID=
DHAN_PIN=
DHAN_TOTP_SECRET=

# ── Telegram ──
# BotFather token used to receive incoming alerts
BOT_TOKEN=

# Telegram user-id allowlist — only these accounts can send commands
ALLOWED_USER_ID=

# Bot token + chat id for outgoing trade-status alerts (can equal BOT_TOKEN)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
